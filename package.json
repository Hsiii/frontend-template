{
    "name": "frontend-template",
    "version": "0.2.0",
    "private": true,
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Hsiii/frontend-template.git"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "release": "node scripts/release-create-hsi-app.mjs",
        "check": "tsc -p tsconfig.json --noEmit && eslint . && node --check packages/create-hsi-app/bin/create-hsi-app.mjs && node --check scripts/release-create-hsi-app.mjs && prettier . --check && vite build"
    },
    "dependencies": {
        "@tanstack/react-query": "5.100.11",
        "lucide-react": "0.554.0",
        "react": "19.2.6",
        "react-dom": "19.2.6"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "4.7.1",
        "@types/react": "19.2.15",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.2",
        "complete-lint": "5.11.0",
        "eslint": "10.4.0",
        "eslint-config-complete": "4.7.2",
        "eslint-import-resolver-typescript": "4.4.4",
        "prettier": "3.8.3",
        "typescript": "6.0.3",
        "vite": "8.0.13"
    }
}
